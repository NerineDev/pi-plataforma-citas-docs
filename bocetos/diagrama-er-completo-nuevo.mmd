        string invoice_number
        string invoice_type
        decimal total_amount
        string status
        boolean is_reversal
        int reverses_invoice_id FK
        int replaces_invoice_id FK
    }

    THREADS {
        int thread_id PK
        int user_id FK
        int pro_id FK
        int booking_id FK
        string status
    }

    MESSAGES {
        int message_id PK
        int thread_id FK
        int sender_id FK
        datetime sent_at
        boolean active
    }

    SUPPORT_TICKETS {
        int ticket_id PK
        int user_id FK
        string subject
        string status
        boolean active
    }

