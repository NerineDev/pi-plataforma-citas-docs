erDiagram

    USERS {
        int user_id PK
        string username
        string email
        boolean active
    }

    PRO_PROFILES {
        int pro_profile_id PK
        int user_id FK
        string display_name
        string status
    }

    BOOKINGS {
        int booking_id PK
        int client_user_id FK
        int pro_profile_id FK
        int service_id FK
        datetime booking_start
        datetime booking_end
        decimal price_total
        string currency_code
        string status
    }

    BILLING_DETAILS {
        int billing_detail_id PK
        int user_id FK
        string legal_name
        string tax_id
        string address_line_1
        string city
        string postal_code
        string country_code
        boolean is_default
    }

    INVOICES {
        int invoice_id PK
        int booking_id FK
        int billing_detail_id FK
        string invoice_number
        string invoice_type
        decimal subtotal_amount
        decimal tax_amount
        decimal total_amount
        string status
        boolean is_reversal
        int reverses_invoice_id FK
        int replaces_invoice_id FK
    }

    PAYMENTS {
        int payment_id PK
        int booking_id FK
        int invoice_id FK
        decimal amount
        string payment_method
        string status
        string receipt_number
        datetime paid_at
    }

    THREADS {
        int thread_id PK
        int user_id FK
        int pro_id FK
        int booking_id FK
        string subject
        string status
    }

    MESSAGES {
        int message_id PK
        int thread_id FK
        int sender_id FK
        text body
        datetime sent_at
        boolean active
    }

    SUPPORT_TICKETS {
        int ticket_id PK
        int user_id FK
        string subject
        text description
        string status
        boolean active
    }

    USERS ||--o{ BILLING_DETAILS : stores
    USERS ||--o{ BOOKINGS : makes
    PRO_PROFILES ||--o{ BOOKINGS : receives

    BOOKINGS ||--o{ PAYMENTS : generates
    BOOKINGS ||--o{ INVOICES : generates
    PAYMENTS }o--o| INVOICES : linked_to
    BILLING_DETAILS ||--o{ INVOICES : used_for
    INVOICES ||--o{ INVOICES : rectifies

    USERS ||--o{ THREADS : starts
    PRO_PROFILES ||--o{ THREADS : participates
    BOOKINGS ||--o{ THREADS : relates_to
    THREADS ||--o{ MESSAGES : contains
    USERS ||--o{ MESSAGES : sends
    USERS ||--o{ SUPPORT_TICKETS : opens
